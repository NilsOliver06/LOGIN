@{
    ViewData["Title"] = "Reportes - Candy Shoes";
    var esAdmin = Context.Session.GetString("UsuarioRol") == "Admin";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger rounded-3 border-0 shadow-sm mb-4">
        <i class="fas fa-exclamation-circle me-2"></i>
        <strong>Error:</strong> @TempData["Error"]
    </div>
}

@if (!esAdmin)
{
    <div class="alert alert-danger text-center shadow-sm">
        <i class="fas fa-lock me-2"></i> No tienes permiso para acceder a esta sección.
    </div>
    return;
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="section-title mb-2">
                <i class="fas fa-chart-line text-candy-primary me-2"></i>Panel de Reportes
            </h1>
            <p class="text-muted">Genera informes oficiales en formato PDF listos para imprimir o guardar.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-danger bg-opacity-10 p-3 rounded-3 text-danger me-3">
                                <i class="fas fa-file-invoice-dollar fa-2x"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0">Reporte de Ventas</h4>
                                <small class="text-muted">Historial detallado de pedidos</small>
                            </div>
                        </div>
                        <p class="text-muted small">Selecciona un rango opcional de fechas para filtrar los movimientos financieros de la tienda.</p>
                    </div>

                    <form method="get" asp-action="VentasPdf" class="mt-3">
                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label class="form-label small fw-semibold text-secondary">Desde</label>
                                <input type="date" name="fechaInicio" class="form-control form-control-sm rounded-3" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold text-secondary">Hasta</label>
                                <input type="date" name="fechaFin" class="form-control form-control-sm rounded-3" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-danger w-100 rounded-pill py-2 shadow-sm">
                            <i class="fas fa-file-pdf me-2"></i>Descargar PDF de Ventas
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary bg-opacity-10 p-3 rounded-3 text-primary me-3">
                                <i class="fas fa-boxes fa-2x"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0">Inventario de Productos</h4>
                                <small class="text-muted">Stock y catálogo actual</small>
                            </div>
                        </div>
                        <p class="text-muted small">Obtén un balance general de los productos registrados en el sistema, incluyendo cantidades en almacén y precios unitarios.</p>
                    </div>

                    <div class="mt-4 pt-2">
                        <a asp-action="ProductosPdf" class="btn btn-primary w-100 rounded-pill py-2 shadow-sm">
                            <i class="fas fa-file-pdf me-2"></i>Descargar PDF de Inventario
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>