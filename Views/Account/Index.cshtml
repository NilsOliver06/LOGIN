@model List<LOGIN.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios - Candy Shoes";
}

<div class="container">
    <!-- Encabezado -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="section-title">
                        <i class="fas fa-users text-candy-primary me-2"></i>Gestión de Usuarios
                    </h1>
                    <p class="text-muted">Administra todos los usuarios de Candy Shoes</p>
                </div>
                <a asp-action="Register" class="btn btn-candy">
                    <i class="fas fa-user-plus me-2"></i>Nuevo Usuario
                </a>
            </div>
        </div>
    </div>

    <!-- Mensajes -->
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success rounded-3 border-0 shadow-sm alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3 border-0 shadow-sm alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Tabla de usuarios -->
    <div class="card-candy">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-candy-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Edad</th>
                            <th>Ciudad</th>
                            <th>Registro</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="fas fa-user-slash" style="font-size: 3rem; color: #ddd;"></i>
                                    <h5 class="mt-3 text-muted">No hay usuarios registrados</h5>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                // 👇 CAMBIO: Usamos "esAdminUser" en lugar de "esAdmin"
                                var esAdminUser = item.Email == "admin@candyshoes.pe";
                                <tr>
                                    <td class="ps-4 fw-bold text-muted">#@item.Id</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fas fa-user-circle" style="color: #FF6B6B;"></i>
                                            <span class="fw-semibold">@item.Nombre</span>
                                            @if (esAdminUser)
                                            {
                                                <span class="badge bg-danger rounded-pill ms-2">Admin</span>
                                            }
                                        </div>
                                    </td>
                                    <td>@item.Email</td>
                                    <td>@item.Edad</td>
                                    <td>@item.Ciudad</td>
                                    <td class="text-muted small">@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Editar">
                                                <i class="fas fa-pencil-alt"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger rounded-end-3" title="Eliminar">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>