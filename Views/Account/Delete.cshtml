@model LOGIN.Models.Usuario

@{
    ViewData["Title"] = "Eliminar Usuario - Candy Shoes";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-candy">
            <div class="card-body p-4 p-lg-5">
                <!-- Encabezado -->
                <div class="text-center mb-4">
                    <div class="bg-candy-light rounded-circle d-inline-flex p-3 mb-3" style="background: linear-gradient(135deg, #DC2626 0%, #EF4444 100%) !important;">
                        <i class="fas fa-user-slash text-white" style="font-size: 2rem;"></i>
                    </div>
                    <h2 class="fw-bold text-danger">Eliminar Usuario</h2>
                    <p class="text-danger">⚠️ Esta acción no se puede deshacer</p>
                </div>

                <!-- Usuario a eliminar -->
                <div class="text-center mb-4">
                    <div class="bg-candy-light rounded-4 p-4 d-inline-block" style="background: linear-gradient(135deg, #FFF8F0 0%, #FFE8D6 100%);">
                        <i class="fas fa-user-circle" style="font-size: 4rem; color: #FF6B6B;"></i>
                    </div>
                    <h4 class="fw-bold mt-3">@Model.Nombre</h4>
                    <p class="text-muted">#@Model.Id</p>
                </div>

                <div class="alert alert-warning rounded-3 border-0">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>¿Estás seguro?</strong> El usuario se eliminará permanentemente del sistema.
                </div>

                <!-- Resumen del usuario -->
                <div class="bg-light rounded-3 p-3 mb-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 fw-semibold">Nombre</dt>
                        <dd class="col-sm-8 text-secondary">@Model.Nombre</dd>

                        <dt class="col-sm-4 fw-semibold">Email</dt>
                        <dd class="col-sm-8 text-secondary">@Model.Email</dd>

                        <dt class="col-sm-4 fw-semibold">Edad</dt>
                        <dd class="col-sm-8 text-secondary">@Model.Edad</dd>

                        <dt class="col-sm-4 fw-semibold">Ciudad</dt>
                        <dd class="col-sm-8 text-secondary">@Model.Ciudad</dd>
                    </dl>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 justify-content-center">
                        <a asp-action="Index" class="btn btn-candy-outline px-4">
                            <i class="fas fa-times-circle me-1"></i>Cancelar
                        </a>
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="fas fa-trash-alt me-2"></i>Sí, eliminar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>