<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Candy Shoes 🍬👟</title>

    <!-- ===== PWA META TAGS ===== -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#FF6B6B">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Candy Shoes">

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- Google Fonts - Poppins -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Estilos personalizados Candy Shoes -->
    <link rel="stylesheet" href="~/css/candy-shoes.css" asp-append-version="true" />

    <!-- Estilos adicionales -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ===== HEADER / NAVBAR ===== -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-candy">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-shoe-prints"></i> Candy Shoes
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCandy">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarCandy">
                    <ul class="navbar-nav me-auto">
                        <!-- INICIO - Visible para todos -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Inicio
                            </a>
                        </li>

                        @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                        {
                            <!-- TIENDA - Visible para todos los logueados -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tienda" asp-action="Index">
                                    <i class="fas fa-store"></i> Tienda
                                </a>
                            </li>

                            <!-- MIS COMPRAS - Visible para todos los logueados -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tienda" asp-action="MisCompras">
                                    <i class="fas fa-receipt"></i> Mis Compras
                                </a>
                            </li>

                            <!-- ============================================================ -->
                            <!-- 👇 SECCIÓN ADMIN - SOLO VISIBLE PARA ADMINISTRADORES -->
                            <!-- ============================================================ -->
                            var rol = Context.Session.GetString("UsuarioRol");
                            if (rol == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="ProductosView" asp-action="Index">
                                        <i class="fas fa-boxes"></i> Inventario
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Account" asp-action="Index">
                                        <i class="fas fa-users me-1"></i> Usuarios
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Tienda" asp-action="AdminPedidos">
                                        <i class="fas fa-clipboard-list me-1"></i> Pedidos
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Reportes" asp-action="Index">
                                        <i class="fas fa-chart-bar me-1"></i> Reportes
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                        {
                            <!-- Carrito -->
                            <li class="nav-item">
                                <a class="nav-link position-relative" asp-controller="Tienda" asp-action="Carrito">
                                    <i class="fas fa-shopping-cart"></i>
                                    <span class="cart-badge" id="cartCount">
                                        @{
                                            var count = 0;
                                            try
                                            {
                                                using var scope = Context.RequestServices.CreateScope();
                                                var db = scope.ServiceProvider.GetService<LOGIN.Data.ApplicationDbContext>();
                                                var userId = int.Parse(Context.Session.GetString("UsuarioId") ?? "0");
                                                count = db?.CarritoItems.Where(c => c.UsuarioId == userId).Sum(c => c.Cantidad) ?? 0;
                                            }
                                            catch { }
                                        }
                                        @count
                                    </span>
                                </a>
                            </li>

                            <!-- Nombre de usuario + Badge Admin -->
                            <li class="nav-item">
                                <span class="navbar-text d-flex align-items-center">
                                    <i class="fas fa-user-circle me-1"></i>
                                    @Context.Session.GetString("UsuarioNombre")
                                    @if (Context.Session.GetString("UsuarioRol") == "Admin")
                                    {
                                        <span class="badge bg-danger ms-1">Admin</span>
                                    }
                                </span>
                            </li>

                            <!-- Mi Perfil -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Edit" asp-route-id="@(Context.Session.GetString("UsuarioId"))">
                                    <i class="fas fa-user-edit me-1"></i> Mi Perfil
                                </a>
                            </li>

                            <!-- Salir -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt"></i> Salir
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt"></i> Iniciar Sesión
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="fas fa-user-plus"></i> Registrarse
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <main class="flex-grow-1">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <!-- ===== FOOTER CANDY SHOES ===== -->
    <footer class="footer-candy">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 text-center text-md-start">
                    <h5 class="text-white fw-bold">
                        <i class="fas fa-shoe-prints me-2"></i>Candy Shoes
                    </h5>
                    <p class="small mb-0">© @DateTime.Now.Year - Calzado con estilo y dulzura</p>
                </div>
                <div class="col-md-4 text-center">
                    <div class="social-icons">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-tiktok"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <small>
                        <i class="fas fa-phone me-1"></i> +51 999 999 999
                        <br>
                        <i class="fas fa-envelope me-1"></i> info@candyshoes.pe
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- ===== SCRIPTS ===== -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Script para actualizar contador del carrito vía AJAX -->
    <script>
        function actualizarContadorCarrito() {
        $.get('/Tienda/GetCarritoCount', function(data) {
        $('#cartCount').text(data.count);
        });
        }

        $(document).on('click', '.add-to-cart', function() {
        setTimeout(actualizarContadorCarrito, 500);
        });
    </script>

    <!-- ===== PWA - REGISTRO SERVICE WORKER ===== -->
    <script>
        if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
        navigator.serviceWorker.register('/service-worker.js')
        .then(function(registration) {
        console.log('✅ Service Worker registrado correctamente');
        })
        .catch(function(error) {
        console.log('❌ Error al registrar Service Worker:', error);
        });
        });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>