@model LOGIN.Models.Producto

@{
    ViewData["Title"] = "Nuevo Producto - Candy Shoes";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-candy">
            <div class="card-body p-4 p-lg-5">
                <div class="text-center mb-4">
                    <div class="bg-candy-light rounded-circle d-inline-flex p-3 mb-3" style="background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%) !important;">
                        <i class="fas fa-plus-circle text-white" style="font-size: 2rem;"></i>
                    </div>
                    <h2 class="fw-bold">Nuevo Producto</h2>
                    <p class="text-muted">Agrega un nuevo producto al inventario de Candy Shoes</p>
                </div>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold">
                            <i class="fas fa-tag text-candy-primary me-1"></i>Nombre *
                        </label>
                        <input asp-for="Nombre" class="form-control form-control-lg rounded-3"
                               placeholder="Ej. Tenis Nike Air Max" required />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-semibold">
                            <i class="fas fa-align-left text-candy-primary me-1"></i>Descripción
                        </label>
                        <textarea asp-for="Descripcion" class="form-control rounded-3" rows="3"
                                  placeholder="Descripción opcional del producto"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Cantidad" class="form-label fw-semibold">
                                <i class="fas fa-box text-candy-primary me-1"></i>Cantidad *
                            </label>
                            <input asp-for="Cantidad" class="form-control form-control-lg rounded-3"
                                   type="number" min="0" placeholder="0" required />
                            <span asp-validation-for="Cantidad" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Precio" class="form-label fw-semibold">
                                <i class="fas fa-dollar-sign text-candy-primary me-1"></i>Precio *
                            </label>
                            <input asp-for="Precio" class="form-control form-control-lg rounded-3"
                                   type="number" step="0.01" min="0.01" placeholder="0.00" required />
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- ============================================================ -->
                    <!-- 🔗 ENLACE DE IMAGEN CON VISTA PREVIA (NUEVO) -->
                    <!-- ============================================================ -->
                    <div class="mb-3 mt-3">
                        <label asp-for="ImagenUrl" class="form-label fw-semibold">
                            <i class="fas fa-link text-candy-primary me-1"></i>Enlace de la Imagen (URL)
                        </label>
                        <input asp-for="ImagenUrl" id="urlInput" class="form-control rounded-3" type="url"
                               placeholder="https://ejemplo.com/imagen.jpg" />
                        <span asp-validation-for="ImagenUrl" class="text-danger small"></span>
                        <small class="text-muted d-block mt-1">Puedes subir la imagen a ImgBB o PostImages y pegar el enlace directo aquí.</small>
                    </div>

                    <!-- Contenedor de Vista Previa -->
                    <div class="mb-3 text-center d-none" id="previewContainer">
                        <small class="text-muted d-block mb-2 fw-semibold">Vista previa de la imagen:</small>
                        <img id="imgPreview" src="" alt="Vista previa" class="img-thumbnail rounded-3 shadow-sm" style="max-height: 150px; object-fit: contain;" />
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-candy-outline px-4">
                            <i class="fas fa-arrow-left me-1"></i>Cancelar
                        </a>
                        <button type="submit" class="btn btn-candy px-4">
                            <i class="fas fa-save me-2"></i>Guardar Producto
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
        function verificarVistaPrevia() {
        var url = $('#urlInput').val().trim();
        if (url) {
        $('#imgPreview').attr('src', url);
        $('#previewContainer').removeClass('d-none');
        } else {
        $('#previewContainer').addClass('d-none');
        }
        }

        // Escuchar cambios en el input de la URL para actualizar la vista previa en tiempo real
        $('#urlInput').on('input change', function() {
        verificarVistaPrevia();
        });

        // Verificar si ya viene con una URL cargada por defecto
        verificarVistaPrevia();
        });
    </script>
}