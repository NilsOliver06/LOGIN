@model IEnumerable<LOGIN.Models.Producto>

@{
    ViewData["Title"] = "Inventario - Candy Shoes";
}

<div class="container">
    <!-- Encabezado -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="section-title">
                        <i class="fas fa-boxes text-candy-primary me-2"></i>Gestión de Inventario
                    </h1>
                    <p class="text-muted">Administra todos los productos de Candy Shoes</p>
                </div>
                <a asp-action="Create" class="btn btn-candy">
                    <i class="fas fa-plus-circle me-2"></i>Nuevo Producto
                </a>
            </div>
        </div>
    </div>

    <!-- Mensajes de éxito -->
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success rounded-3 border-0 shadow-sm alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Resumen rápido -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="bg-white rounded-3 p-3 shadow-sm text-center">
                <h5 class="text-muted small">Total Productos</h5>
                <h3 class="fw-bold text-candy-primary">@Model.Count()</h3>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="bg-white rounded-3 p-3 shadow-sm text-center">
                <h5 class="text-muted small">Con Stock</h5>
                <h3 class="fw-bold text-success">@Model.Count(p => p.Cantidad > 0)</h3>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="bg-white rounded-3 p-3 shadow-sm text-center">
                <h5 class="text-muted small">Agotados</h5>
                <h3 class="fw-bold text-danger">@Model.Count(p => p.Cantidad == 0)</h3>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="bg-white rounded-3 p-3 shadow-sm text-center">
                <h5 class="text-muted small">Bajo Stock</h5>
                <h3 class="fw-bold text-warning">@Model.Count(p => p.Cantidad > 0 && p.Cantidad < 5)</h3>
            </div>
        </div>
    </div>

    <!-- Tabla de productos -->
    <div class="card-candy">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-candy-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Producto</th>
                            <th class="d-none d-md-table-cell">Descripción</th>
                            <th class="text-center">Stock</th>
                            <th class="text-end">Precio</th>
                            <th class="text-end">Registro</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="fas fa-box-open" style="font-size: 3rem; color: #ddd;"></i>
                                    <h5 class="mt-3 text-muted">No hay productos registrados</h5>
                                    <a asp-action="Create" class="btn btn-candy mt-2">
                                        <i class="fas fa-plus-circle me-2"></i>Agregar el primero
                                    </a>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted">#@item.Id</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fas fa-shoe-prints" style="color: #FF6B6B;"></i>
                                            <span class="fw-semibold">@item.Nombre</span>
                                        </div>
                                    </td>
                                    <td class="d-none d-md-table-cell text-muted small">
                                        @(item.Descripcion?.Length > 40 ? item.Descripcion.Substring(0, 40) + "..." : item.Descripcion ?? "---")
                                    </td>
                                    <td class="text-center">
                                        @if (item.Cantidad == 0)
                                        {
                                            <span class="badge bg-danger rounded-pill px-3 py-2">
                                                <i class="fas fa-times-circle me-1"></i>Agotado
                                            </span>
                                        }
                                        else if (item.Cantidad < 5)
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
                                                <i class="fas fa-exclamation-triangle me-1"></i>@item.Cantidad uds
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success rounded-pill px-3 py-2">
                                                <i class="fas fa-check-circle me-1"></i>@item.Cantidad uds
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold text-candy-primary">
                                        @item.Precio.ToString("C")
                                    </td>
                                    <td class="text-end text-muted small">
                                        @item.FechaRegistro.ToString("dd/MM/yyyy")
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info rounded-start-3" title="Ver">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Editar">
                                                <i class="fas fa-pencil-alt"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger rounded-end-3" title="Eliminar">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>