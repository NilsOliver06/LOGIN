@model LOGIN.Models.Producto

@{
    ViewData["Title"] = "Detalles - Candy Shoes";
    var usuarioId = Context.Session.GetString("UsuarioId");
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card-candy">
            <div class="card-body p-4 p-lg-5">
                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a asp-action="Index" class="text-decoration-none">
                                <i class="fas fa-store me-1"></i>Tienda
                            </a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">
                            @Model.Nombre
                        </li>
                    </ol>
                </nav>

                <div class="row g-4">
                    <!-- Imagen / Icono del producto -->
                    <div class="col-md-5 text-center">
                        <div class="bg-candy-light rounded-4 p-5" style="background: linear-gradient(135deg, #FFF8F0 0%, #FFE8D6 100%);">
                            <i class="fas fa-shoe-prints" style="font-size: 8rem; color: #FF6B6B;"></i>
                        </div>
                    </div>

                    <!-- Información del producto -->
                    <div class="col-md-7">
                        <h1 class="fw-bold display-6">@Model.Nombre</h1>

                        <!-- Precio y estado -->
                        <div class="mt-3">
                            <span class="badge bg-candy-primary rounded-pill px-4 py-2 fs-6">
                                @Model.Precio.ToString("C")
                            </span>
                            @if (Model.Cantidad > 0)
                            {
                                <span class="badge bg-success rounded-pill px-4 py-2 ms-2">
                                    <i class="fas fa-check-circle me-1"></i>Disponible
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger rounded-pill px-4 py-2 ms-2">
                                    <i class="fas fa-times-circle me-1"></i>Agotado
                                </span>
                            }
                        </div>

                        <hr />

                        <!-- Descripción -->
                        <h6 class="fw-bold">
                            <i class="fas fa-align-left me-2 text-candy-primary"></i>Descripción
                        </h6>
                        <p class="text-muted">
                            @(Model.Descripcion ?? "Sin descripción disponible")
                        </p>

                        <!-- Estadísticas rápidas -->
                        <div class="row g-3 mt-3">
                            <div class="col-6">
                                <div class="bg-light rounded-3 p-3 text-center">
                                    <small class="text-muted">Stock disponible</small>
                                    <h4 class="fw-bold @(Model.Cantidad == 0 ? "text-danger" : Model.Cantidad < 5 ? "text-warning" : "text-success")">
                                        @Model.Cantidad
                                    </h4>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light rounded-3 p-3 text-center">
                                    <small class="text-muted">Registrado</small>
                                    <h6 class="fw-bold">@Model.FechaRegistro.ToString("dd/MM/yyyy")</h6>
                                </div>
                            </div>
                        </div>

                        <!-- Botones de acción -->
                        <div class="d-flex gap-2 mt-4">
                            @if (Model.Cantidad > 0)
                            {
                                <button class="btn btn-candy btn-lg flex-grow-1 add-to-cart" data-id="@Model.Id" data-nombre="@Model.Nombre">
                                    <i class="fas fa-cart-plus me-2"></i>Agregar al Carrito
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-lg flex-grow-1" disabled>
                                    <i class="fas fa-times-circle me-2"></i>Agotado
                                </button>
                            }
                            <a asp-action="Index" class="btn btn-candy-outline btn-lg" title="Volver a la tienda">
                                <i class="fas fa-arrow-left"></i>
                            </a>
                        </div>

                        <!-- Información adicional -->
                        <div class="mt-4 pt-3 border-top">
                            <div class="d-flex flex-wrap gap-3 text-muted small">
                                <span>
                                    <i class="fas fa-truck text-candy-primary me-1"></i>
                                    Envío a todo el país
                                </span>
                                <span>
                                    <i class="fas fa-undo text-candy-primary me-1"></i>
                                    Cambios hasta 7 días
                                </span>
                                <span>
                                    <i class="fas fa-shield-alt text-candy-primary me-1"></i>
                                    Compra segura
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Script para agregar al carrito -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
    $('.add-to-cart').click(function() {
    var btn = $(this);
    var productoId = btn.data('id');
    var nombre = btn.data('nombre');

    // Deshabilitar botón temporalmente
    btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Agregando...');

    $.post('/Tienda/AgregarAlCarrito', { productoId: productoId, cantidad: 1 })
    .done(function(response) {
    if (response.success) {
    // Actualizar badge del carrito
    $('#cartBadge').text(response.count);

    // Feedback visual
    btn.removeClass('btn-candy').addClass('btn-success')
    .html('<i class="fas fa-check me-2"></i>Agregado ✓');

    // Mostrar notificación
    mostrarNotificacion('✓ ' + nombre + ' agregado al carrito');

    // Recargar después de 1.5s para actualizar stock
    setTimeout(function() {
    location.reload();
    }, 1500);
    } else {
    btn.html('<i class="fas fa-cart-plus me-2"></i>Agregar al Carrito')
    .prop('disabled', false);
    alert(response.message || 'Error al agregar');
    }
    })
    .fail(function() {
    btn.html('<i class="fas fa-cart-plus me-2"></i>Agregar al Carrito')
    .prop('disabled', false);
    alert('Error de conexión. Intenta nuevamente.');
    });
    });
    });

    function mostrarNotificacion(mensaje) {
    var notificacion = $('<div class="notificacion-flotante">' + mensaje + '</div>');
    $('body').append(notificacion);
    setTimeout(function() {
    notificacion.fadeOut(500, function() { $(this).remove(); });
    }, 3000);
    }
</script>

<style>
    .breadcrumb {
    background: transparent;
    padding: 0;
    margin-bottom: 1.5rem;
    }

    .breadcrumb-item a {
    color: #FF6B6B;
    font-weight: 500;
    }

    .breadcrumb-item.active {
    color: #2C3E50;
    font-weight: 600;
    }

    .bg-candy-light {
    background: #FFF8F0;
    }

    /* Clase de apoyo por si no estuviera en tu CSS global */
    .notificacion-flotante {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #2ecc71;
    color: white;
    padding: 12px 25px;
    border-radius: 30px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    z-index: 9999;
    font-weight: bold;
    }
</style>