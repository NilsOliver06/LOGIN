@model IEnumerable<LOGIN.Models.Producto>

@{
    ViewData["Title"] = "Tienda - Candy Shoes";
    var usuarioId = Context.Session.GetString("UsuarioId");
}

<div class="container-fluid">
    <div class="row">
        <!-- ============================================================ -->
        <!-- 🍬 PANEL DE FILTROS - REDISEÑO PREMIUM -->
        <!-- ============================================================ -->
        <div class="col-lg-3 col-md-4">
            <div class="filtros-panel">
                <!-- Cabecera con ícono y botón sutil -->
                <div class="filtros-header">
                    <div class="filtros-header-left">
                        <i class="fas fa-sliders-h filtros-icon"></i>
                        <h5 class="filtros-title">Filtros</h5>
                    </div>
                    <button id="limpiarFiltros" class="btn-limpiar">
                        <i class="fas fa-undo-alt me-1"></i> Limpiar
                    </button>
                </div>

                <div class="filtros-divider"></div>

                <!-- ============================================================ -->
                <!-- 💰 FILTRO POR PRECIO -->
                <!-- ============================================================ -->
                <div class="filtro-grupo">
                    <label class="filtro-label">
                        <i class="fas fa-tag filtro-icon"></i> Rango de Precio
                    </label>
                    <div class="precio-inputs">
                        <div class="precio-input-wrapper">
                            <span class="precio-symbol">S/</span>
                            <input type="number" id="precioMin" class="precio-input" placeholder="Mín" min="0" />
                        </div>
                        <span class="precio-separator">—</span>
                        <div class="precio-input-wrapper">
                            <span class="precio-symbol">S/</span>
                            <input type="number" id="precioMax" class="precio-input" placeholder="Máx" min="0" />
                        </div>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- 📊 FILTRO POR STOCK -->
                <!-- ============================================================ -->
                <div class="filtro-grupo">
                    <label class="filtro-label">
                        <i class="fas fa-box filtro-icon"></i> Disponibilidad
                    </label>
                    <div class="select-wrapper">
                        <select id="filtroStock" class="filtro-select">
                            <option value="todos">Todos los productos</option>
                            <option value="con-stock">✓ Con stock</option>
                            <option value="sin-stock">✕ Sin stock</option>
                            <option value="bajo-stock">⚠ Bajo stock (&lt; 5)</option>
                        </select>
                        <i class="fas fa-chevron-down select-arrow"></i>
                    </div>
                </div>

                <!-- Contador de resultados -->
                <div class="filtros-footer">
                    <span id="resultadosCount" class="resultados-count">
                        <i class="fas fa-box-open me-1"></i> <span id="contadorResultados">0</span> productos
                    </span>
                </div>

                <!-- Botón toggle para móvil -->
                <div class="d-block d-md-none text-center mt-3">
                    <button id="toggleFiltros" class="btn-toggle-mobile">
                        <i class="fas fa-filter me-2"></i> Mostrar/Ocultar Filtros
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ============================================================ -->
<!-- 📱 SCRIPT PARA TOGGLE EN MÓVIL Y FILTROS -->
<!-- ============================================================ -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
    // ============================================================
    // TOGGLE FILTROS EN MÓVIL
    // ============================================================
    $('#toggleFiltros').click(function() {
    $('.filtros-panel').toggleClass('visible');
    $(this).html($('.filtros-panel').hasClass('visible') ?
    '<i class="fas fa-times me-2"></i> Ocultar Filtros' :
    '<i class="fas fa-filter me-2"></i> Mostrar Filtros');
    });

    // Mostrar filtros en escritorio por defecto
    if ($(window).width() > 767) {
    $('.filtros-panel').show();
    }

    // ============================================================
    // FILTROS AUTOMÁTICOS
    // ============================================================
    function filtrarProductos() {
    var precioMin = parseFloat($('#precioMin').val()) || 0;
    var precioMax = parseFloat($('#precioMax').val()) || Infinity;
    var stockFilter = $('#filtroStock').val();

    var count = 0;

    $('.producto-item').each(function() {
    var precio = parseFloat($(this).data('precio'));
    var stock = parseInt($(this).data('stock'));

    var mostrar = true;

    // Filtro por precio
    if (precio < precioMin || precio > precioMax) {
    mostrar = false;
    }

    // Filtro por stock
    if (mostrar) {
    if (stockFilter === 'con-stock' && stock <= 0) {
    mostrar = false;
    } else if (stockFilter === 'sin-stock' && stock > 0) {
    mostrar = false;
    } else if (stockFilter === 'bajo-stock' && (stock >= 5 || stock <= 0)) {
    mostrar = false;
    }
    }

    if (mostrar) {
    $(this).show();
    count++;
    } else {
    $(this).hide();
    }
    });

    // Actualizar contador
    $('#resultadosCount').text(count + ' productos encontrados');
    }

    // Aplicar filtros automáticamente al cambiar
    $('#precioMin, #precioMax, #filtroStock').on('input change', function() {
    filtrarProductos();
    });

    // ============================================================
    // LIMPIAR FILTROS
    // ============================================================
    $('#limpiarFiltros').click(function() {
    $('#precioMin').val('');
    $('#precioMax').val('');
    $('#filtroStock').val('todos');
    filtrarProductos();
    });

    // ============================================================
    // AGREGAR AL CARRITO
    // ============================================================
    $('.add-to-cart').click(function() {
    var btn = $(this);
    var productoId = btn.data('id');
    var nombre = btn.data('nombre');

    btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Agregando...');

    $.post('/Tienda/AgregarAlCarrito', { productoId: productoId, cantidad: 1 })
    .done(function(response) {
    if (response.success) {
    $('#cartBadge').text(response.count);
    btn.removeClass('btn-candy').addClass('btn-success')
    .html('<i class="fas fa-check me-1"></i>Agregado');

    setTimeout(function() {
    btn.removeClass('btn-success').addClass('btn-candy')
    .html('<i class="fas fa-cart-plus me-1"></i>Agregar')
    .prop('disabled', false);
    }, 2000);

    mostrarNotificacion('✓ ' + nombre + ' agregado al carrito');
    } else {
    btn.html('<i class="fas fa-cart-plus me-1"></i>Agregar')
    .prop('disabled', false);
    alert(response.message || 'Error al agregar');
    }
    })
    .fail(function() {
    btn.html('<i class="fas fa-cart-plus me-1"></i>Agregar')
    .prop('disabled', false);
    alert('Error de conexión. Intenta nuevamente.');
    });
    });

    // ============================================================
    // NOTIFICACIÓN FLOTANTE
    // ============================================================
    function mostrarNotificacion(mensaje) {
    var notificacion = $('<div class="notificacion-flotante">' + mensaje + '</div>');
    $('body').append(notificacion);
    setTimeout(function() {
    notificacion.fadeOut(500, function() { $(this).remove(); });
    }, 3000);
    }

    // Ejecutar filtros al cargar (para inicializar contador)
    setTimeout(filtrarProductos, 500);
    });
</script>