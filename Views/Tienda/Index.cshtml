@model IEnumerable<LOGIN.Models.Producto>

@{
    ViewData["Title"] = "Tienda - Candy Shoes";
    var usuarioId = Context.Session.GetString("UsuarioId");

    // Obtener categorías únicas para el dropdown (simuladas)
    var categorias = new List<string> { "Todos", "Running", "Casual", "Deportivos", "Urbanos" };
}

<div class="container-fluid">
    <div class="row">
        <!-- ============================================================ -->
        <!-- 📌 PANEL DE FILTROS - LATERAL -->
        <!-- ============================================================ -->
        <div class="col-lg-3 col-md-4">
            <div class="filtros-panel">
                <!-- Título del panel (visible en escritorio) -->
                <div class="filtros-header d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-filter text-candy-primary me-2"></i>Filtros
                    </h5>
                    <!-- Botón "Limpiar" -->
                    <button id="limpiarFiltros" class="btn btn-sm btn-candy-outline rounded-pill">
                        <i class="fas fa-undo me-1"></i> Limpiar
                    </button>
                </div>

                <hr />

                <!-- ============================================================ -->
                <!-- 🔽 FILTRO POR CATEGORÍA -->
                <!-- ============================================================ -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-tags me-1"></i>Categoría
                    </label>
                    <select id="filtroCategoria" class="form-select rounded-3">
                        @foreach (var cat in categorias)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>

                <!-- ============================================================ -->
                <!-- 💰 FILTRO POR PRECIO -->
                <!-- ============================================================ -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-dollar-sign me-1"></i>Rango de Precio
                    </label>
                    <div class="row g-2">
                        <div class="col-6">
                            <input type="number" id="precioMin" class="form-control rounded-3" placeholder="Mín" min="0" />
                        </div>
                        <div class="col-6">
                            <input type="number" id="precioMax" class="form-control rounded-3" placeholder="Máx" min="0" />
                        </div>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- 📊 FILTRO POR STOCK -->
                <!-- ============================================================ -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-box me-1"></i>Disponibilidad
                    </label>
                    <select id="filtroStock" class="form-select rounded-3">
                        <option value="todos">Todos</option>
                        <option value="con-stock">Con stock</option>
                        <option value="sin-stock">Sin stock</option>
                        <option value="bajo-stock">Bajo stock (&lt; 5)</option>
                    </select>
                </div>

                <!-- ============================================================ -->
                <!-- 🔄 BOTÓN PARA MÓVIL (TOGGLE) -->
                <!-- ============================================================ -->
                <div class="d-block d-md-none text-center mt-3">
                    <button id="toggleFiltros" class="btn btn-candy w-100 rounded-pill">
                        <i class="fas fa-filter me-2"></i> Mostrar/Ocultar Filtros
                    </button>
                </div>
            </div>
        </div>

        <!-- ============================================================ -->
        <!-- 📦 GRID DE PRODUCTOS -->
        <!-- ============================================================ -->
        <div class="col-lg-9 col-md-8">
            <!-- Encabezado de la tienda -->
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                <div>
                    <h1 class="section-title">
                        <i class="fas fa-store text-candy-primary me-2"></i>Nuestra Tienda
                    </h1>
                    <p class="text-muted" id="resultadosCount">Encuentra el calzado perfecto para ti</p>
                </div>
                <a asp-action="Carrito" class="btn btn-candy position-relative">
                    <i class="fas fa-shopping-cart me-2"></i>Carrito
                    <span class="cart-badge" id="cartBadge">
                        @{
                            var count = 0;
                            if (!string.IsNullOrEmpty(usuarioId))
                            {
                                try
                                {
                                    using var scope = Context.RequestServices.CreateScope();
                                    var db = scope.ServiceProvider.GetService<LOGIN.Data.ApplicationDbContext>();
                                    var userId = int.Parse(usuarioId);
                                    count = db?.CarritoItems.Where(c => c.UsuarioId == userId).Sum(c => c.Cantidad) ?? 0;
                                }
                                catch { }
                            }
                        }
                        @count
                    </span>
                </a>
            </div>

            <!-- Grid de productos -->
            <div class="row g-4" id="productosGrid">
                @if (!Model.Any())
                {
                    <div class="col-12">
                        <div class="text-center py-5">
                            <i class="fas fa-box-open" style="font-size: 4rem; color: #ddd;"></i>
                            <h4 class="mt-3 text-muted">No hay productos disponibles</h4>
                            <p class="text-muted">Pronto tendremos novedades para ti</p>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var producto in Model)
                    {
                        <div class="col-md-6 col-xl-4 producto-item"
                             data-nombre="@producto.Nombre.ToLower()"
                             data-categoria="@(producto.Categoria ?? "General")"
                             data-precio="@producto.Precio"
                             data-stock="@producto.Cantidad">
                            <div class="card producto-card h-100">
                                <!-- Etiqueta de estado -->
                                @if (producto.Cantidad == 0)
                                {
                                    <div class="producto-badge bg-danger">
                                        <i class="fas fa-times-circle me-1"></i>Agotado
                                    </div>
                                }
                                else if (producto.Cantidad < 5)
                                {
                                    <div class="producto-badge bg-warning text-dark">
                                        <i class="fas fa-exclamation-triangle me-1"></i>Últimas unidades
                                    </div>
                                }
                                else
                                {
                                    <div class="producto-badge bg-success">
                                        <i class="fas fa-check-circle me-1"></i>Disponible
                                    </div>
                                }

                                <!-- Imagen / Icono -->
                                <div class="card-img-top text-center pt-4 bg-candy-light">
                                    <i class="fas fa-shoe-prints" style="font-size: 5rem; color: #FF6B6B;"></i>
                                </div>

                                <div class="card-body">
                                    <h5 class="card-title fw-bold">@producto.Nombre</h5>
                                    <p class="card-text text-muted small">
                                        @(producto.Descripcion?.Length > 60 ? producto.Descripcion.Substring(0, 60) + "..." : producto.Descripcion ?? "Sin descripción")
                                    </p>
                                    <div class="d-flex justify-content-between align-items-center mt-3">
                                        <span class="fs-4 fw-bold text-candy-primary">
                                            @producto.Precio.ToString("C")
                                        </span>
                                        @if (producto.Cantidad > 0)
                                        {
                                            <button class="btn btn-candy add-to-cart" data-id="@producto.Id" data-nombre="@producto.Nombre">
                                                <i class="fas fa-cart-plus me-1"></i>Agregar
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary" disabled>
                                                <i class="fas fa-times-circle me-1"></i>Agotado
                                            </button>
                                        }
                                    </div>
                                </div>

                                <div class="card-footer bg-white border-top-0 pb-3">
                                    <div class="d-flex justify-content-between">
                                        <a asp-action="Details" asp-route-id="@producto.Id" class="btn btn-sm btn-candy-outline">
                                            <i class="fas fa-eye"></i> Ver
                                        </a>
                                        <small class="text-muted align-self-center">
                                            <i class="fas fa-box me-1"></i>Stock: @producto.Cantidad
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- ============================================================ -->
<!-- 📱 SCRIPT PARA TOGGLE EN MÓVIL -->
<!-- ============================================================ -->
<script>
    $(document).ready(function() {
        // Toggle filtros en móvil
        $('#toggleFiltros').click(function() {
            $('.filtros-panel').toggleClass('visible');
            $(this).html($('.filtros-panel').hasClass('visible') ?
                '<i class="fas fa-times me-2"></i> Ocultar Filtros' :
                '<i class="fas fa-filter me-2"></i> Mostrar Filtros');
        });

        // Mostrar filtros en escritorio por defecto
        if ($(window).width() > 767) {
            $('.filtros-panel').show();
        }
    });
</script>

<!-- ============================================================ -->
<!-- ⚡ SCRIPT PARA AGREGAR AL CARRITO -->
<!-- ============================================================ -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
    // Agregar al carrito
    $('.add-to-cart').click(function() {
    var btn = $(this);
    var productoId = btn.data('id');
    var nombre = btn.data('nombre');

    btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Agregando...');

    $.post('/Tienda/AgregarAlCarrito', { productoId: productoId, cantidad: 1 })
    .done(function(response) {
    if (response.success) {
    $('#cartBadge').text(response.count);
    btn.removeClass('btn-candy').addClass('btn-success')
    .html('<i class="fas fa-check me-1"></i>Agregado');

    setTimeout(function() {
    btn.removeClass('btn-success').addClass('btn-candy')
    .html('<i class="fas fa-cart-plus me-1"></i>Agregar')
    .prop('disabled', false);
    }, 2000);

    mostrarNotificacion('✓ ' + nombre + ' agregado al carrito');
    } else {
    btn.html('<i class="fas fa-cart-plus me-1"></i>Agregar')
    .prop('disabled', false);
    alert(response.message || 'Error al agregar');
    }
    })
    .fail(function() {
    btn.html('<i class="fas fa-cart-plus me-1"></i>Agregar')
    .prop('disabled', false);
    alert('Error de conexión. Intenta nuevamente.');
    });
    });
    });

    function mostrarNotificacion(mensaje) {
    var notificacion = $('<div class="notificacion-flotante">' + mensaje + '</div>');
    $('body').append(notificacion);
    setTimeout(function() {
    notificacion.fadeOut(500, function() { $(this).remove(); });
    }, 3000);
    }
</script>