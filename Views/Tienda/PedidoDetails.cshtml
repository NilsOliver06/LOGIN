@model LOGIN.Models.Pedido

@{
    ViewData["Title"] = $"Pedido #{Model.Id} - Candy Shoes";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card-candy">
            <div class="card-body p-4 p-lg-5">
                <!-- Encabezado -->
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h2 class="fw-bold">
                            <i class="fas fa-receipt text-candy-primary me-2"></i>Pedido #@Model.Id
                        </h2>
                        <p class="text-muted">
                            <i class="fas fa-calendar-alt me-1"></i>
                            @Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")
                        </p>
                    </div>
                    <span class="badge @(Model.Estado.ToString() switch
                          {
                              "Confirmado" => "bg-success",
                              "Entregado" => "bg-primary",
                              "Cancelado" => "bg-danger",
                              "Enviado" => "bg-info",
                              "Pendiente" => "bg-warning text-dark",
                              _ => "bg-secondary"
                          }) rounded-pill px-4 py-2 fs-6">
                        @Model.Estado
                    </span>
                </div>

                <!-- Info del cliente -->
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="bg-light rounded-3 p-3">
                            <h6 class="fw-bold">
                                <i class="fas fa-user text-candy-primary me-2"></i>Cliente
                            </h6>
                            <p class="mb-0 fw-semibold">@Model.Usuario?.Nombre</p>
                            <p class="mb-0 text-muted small">@Model.Usuario?.Email</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="bg-light rounded-3 p-3">
                            <h6 class="fw-bold">
                                <i class="fas fa-truck text-candy-primary me-2"></i>Envío
                            </h6>
                            <p class="mb-0">@Model.DireccionEnvio</p>
                            <p class="mb-0 text-muted small">@Model.MetodoPago</p>
                            <p class="mb-0 text-muted small">Ref: @Model.NumeroReferencia</p>
                        </div>
                    </div>
                </div>

                <!-- Detalles de productos -->
                <h6 class="fw-bold mb-3">
                    <i class="fas fa-box text-candy-primary me-2"></i>Productos
                </h6>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="bg-candy-light">
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio Unitario</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detalle in Model.Detalles!)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fas fa-shoe-prints" style="color: #FF6B6B;"></i>
                                            <span>@detalle.Producto?.Nombre</span>
                                        </div>
                                    </td>
                                    <td class="text-center">@detalle.Cantidad</td>
                                    <td class="text-end">@detalle.PrecioUnitario.ToString("C")</td>
                                    <td class="text-end fw-bold">@detalle.Subtotal.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-bold fs-5">Total:</td>
                                <td class="text-end fw-bold fs-4 text-candy-primary">@Model.Total.ToString("C")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Botones de acción -->
                <div class="d-flex gap-2 justify-content-end mt-4">
                    @if (Model.Estado != EstadoPedido.Cancelado && Model.Estado != EstadoPedido.Entregado)
                    {
                        <a asp-action="Cancelar" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="fas fa-times-circle me-2"></i>Cancelar Pedido
                        </a>
                    }
                    <a asp-action="MisCompras" class="btn btn-candy-outline">
                        <i class="fas fa-arrow-left me-1"></i>Volver
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>