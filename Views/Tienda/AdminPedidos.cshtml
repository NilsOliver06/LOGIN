@model List<LOGIN.Models.Pedido>

@{
    ViewData["Title"] = "Gestión de Pedidos - Candy Shoes";
}

<div class="container">
    <!-- Encabezado -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="section-title">
                        <i class="fas fa-clipboard-list text-candy-primary me-2"></i>Gestión de Pedidos
                    </h1>
                    <p class="text-muted">Administra todos los pedidos de Candy Shoes</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge bg-success rounded-pill px-4 py-2">
                        <i class="fas fa-check-circle me-1"></i>@Model.Count(p => p.Estado == EstadoPedido.Confirmado) Confirmados
                    </span>
                    <span class="badge bg-warning text-dark rounded-pill px-4 py-2">
                        <i class="fas fa-clock me-1"></i>@Model.Count(p => p.Estado == EstadoPedido.Pendiente) Pendientes
                    </span>
                    <span class="badge bg-danger rounded-pill px-4 py-2">
                        <i class="fas fa-times-circle me-1"></i>@Model.Count(p => p.Estado == EstadoPedido.Cancelado) Cancelados
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Mensajes -->
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success rounded-3 border-0 shadow-sm alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3 border-0 shadow-sm alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Tabla de pedidos -->
    <div class="card-candy">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-candy-light">
                        <tr>
                            <th class="ps-4">#Pedido</th>
                            <th>Cliente</th>
                            <th>Fecha</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th>Pago</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="fas fa-receipt" style="font-size: 3rem; color: #ddd;"></i>
                                    <h5 class="mt-3 text-muted">No hay pedidos registrados</h5>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted">#@item.Id</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fas fa-user-circle" style="color: #FF6B6B;"></i>
                                            <span>@item.Usuario?.Nombre</span>
                                        </div>
                                        <small class="text-muted d-block">@item.Usuario?.Email</small>
                                    </td>
                                    <td class="text-muted small">@item.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="fw-bold text-candy-primary">@item.Total.ToString("C")</td>
                                    <td>
                                        <span class="badge @(item.Estado.ToString() switch
                                              {
                                                  "Confirmado" => "bg-success",
                                                  "Entregado" => "bg-primary",
                                                  "Cancelado" => "bg-danger",
                                                  "Enviado" => "bg-info",
                                                  "Pendiente" => "bg-warning text-dark",
                                                  _ => "bg-secondary"
                                              }) rounded-pill px-3 py-2">
                                            @switch (item.Estado.ToString())
                                            {
                                                case "Confirmado":
                                                    <i class="fas fa-check-circle me-1"></i>
                                                    @item.Estado
                                                    ; break;
                                                case "Entregado":

                                                    <i class="fas fa-box-open me-1"></i>
                                                    @item.Estado
                                                    ; break;
                                                case "Cancelado":

                                                    <i class="fas fa-times-circle me-1"></i>
                                                    @item.Estado
                                                    ; break;
                                                case "Enviado":

                                                    <i class="fas fa-truck me-1"></i>
                                                    @item.Estado
                                                    ; break;
                                                case "Pendiente":

                                                    <i class="fas fa-clock me-1"></i>
                                                    @item.Estado
                                                    ; break;
                                                default:

                                                    @item.Estado
                                                    ; break;
                                            }
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                                            @item.MetodoPago
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <!-- 👇 CAMBIO: Ahora usa PedidoDetails -->
                                            <a asp-action="PedidoDetails" asp-route-id="@item.Id" class="btn btn-outline-info rounded-start-3" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (item.Estado != EstadoPedido.Cancelado && item.Estado != EstadoPedido.Entregado)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Cambiar estado">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Cancelar" asp-route-id="@item.Id" class="btn btn-outline-danger rounded-end-3" title="Cancelar">
                                                    <i class="fas fa-times"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <a href="#" class="btn btn-outline-secondary rounded-end-3" disabled>
                                                    <i class="fas fa-lock"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>