@{
    ViewData["Title"] = "Inicio - Candy Shoes";
}

<div class="row align-items-center min-vh-75">
    <div class="col-lg-6">
        <div class="pe-lg-5">
            <h1 class="display-3 fw-bold text-candy-primary">
                <i class="fas fa-shoe-prints me-2"></i>Candy Shoes
            </h1>
            <h2 class="display-6 fw-semibold text-dark mb-4">
                Calzado con <span style="color: #FF6B6B;">estilo</span> y <span style="color: #FECA57;">dulzura</span>
            </h2>
            <p class="lead text-muted mb-4">
                Descubre nuestra colección de tenis exclusivos, diseñados para
                combinar <strong>comodidad</strong> y <strong>tendencia</strong>
                con un toque único que te hará brillar.
            </p>
            <div class="d-flex flex-wrap gap-3">
                <a asp-controller="Tienda" asp-action="Index" class="btn btn-candy btn-lg">
                    <i class="fas fa-store me-2"></i>Ir a la Tienda
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-candy-outline btn-lg">
                    <i class="fas fa-user-plus me-2"></i>Regístrate
                </a>
            </div>

            <!-- Estadísticas rápidas -->
            <div class="row mt-5 g-3">
                <div class="col-4">
                    <div class="text-center">
                        <h3 class="fw-bold text-candy-primary">+500</h3>
                        <p class="text-muted small">Productos</p>
                    </div>
                </div>
                <div class="col-4">
                    <div class="text-center">
                        <h3 class="fw-bold text-candy-secondary">+1000</h3>
                        <p class="text-muted small">Clientes</p>
                    </div>
                </div>
                <div class="col-4">
                    <div class="text-center">
                        <h3 class="fw-bold" style="color: #FECA57;">4.9★</h3>
                        <p class="text-muted small">Valoración</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6 d-none d-lg-block text-center">
        <div class="position-relative">
            <!-- Imagen decorativa de zapatos usando Font Awesome -->
            <div class="bg-candy-light rounded-4 p-5 shadow-lg" style="background: linear-gradient(135deg, #FFF8F0 0%, #FFE8D6 100%);">
                <i class="fas fa-shoe-prints" style="font-size: 10rem; color: #FF6B6B; opacity: 0.8;"></i>
                <div class="mt-3">
                    <span class="badge bg-danger rounded-pill px-4 py-2 me-2">
                        <i class="fas fa-tag me-1"></i>Ofertas
                    </span>
                    <span class="badge bg-warning rounded-pill px-4 py-2">
                        <i class="fas fa-star me-1"></i>Nuevos
                    </span>
                </div>
                <p class="mt-3 text-muted fw-bold">
                    <i class="fas fa-truck me-2 text-candy-primary"></i>
                    Envíos a todo el país
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Sección de categorías destacadas -->
<div class="row mt-5 g-4">
    <div class="col-12">
        <h3 class="section-title text-center mb-4">Categorías Destacadas</h3>
    </div>
    <div class="col-md-4">
        <div class="card-candy text-center p-4">
            <i class="fas fa-running" style="font-size: 3rem; color: #FF6B6B;"></i>
            <h5 class="mt-3">Running</h5>
            <p class="text-muted small">Rendimiento y comodidad</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-candy text-center p-4">
            <i class="fas fa-walking" style="font-size: 3rem; color: #4ECDC4;"></i>
            <h5 class="mt-3">Casual</h5>
            <p class="text-muted small">Estilo diario</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-candy text-center p-4">
            <i class="fas fa-basketball-ball" style="font-size: 3rem; color: #FECA57;"></i>
            <h5 class="mt-3">Deportivos</h5>
            <p class="text-muted small">Para tu mejor juego</p>
        </div>
    </div>
</div>

<!-- Si el usuario está logueado, mostrar mensaje personalizado -->
@if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
{
    <div class="alert alert-success mt-4 rounded-4 border-0 shadow-sm">
        <i class="fas fa-check-circle me-2"></i>
        ¡Bienvenido de vuelta, <strong>@Context.Session.GetString("UsuarioNombre")</strong>!
        <a asp-controller="Tienda" asp-action="Index" class="alert-link ms-2">
            Visita nuestra tienda <i class="fas fa-arrow-right"></i>
        </a>
    </div>
}
<!-- Forzar nuevo deploy en Vercel -->